# Server Configuration
PORT=3001

# Live APIs (Production-grade integrations)
# Provide your OpenAI API key for RAG search, embeddings, layout orchestration, and live translations.
OPENAI_API_KEY=your_openai_api_key_here

# Provide your OpenWeatherMap API key for live weather alerts and precipitation telemetry.
# Get one at: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Vector Database Configuration (PostgreSQL with pgvector)
# Set this to connect to your pgvector database.
# Default for the local docker-compose setup:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monsoon_resilience
